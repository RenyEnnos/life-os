# ===========================
# Optional legacy/experimental Electron Supabase config; not required by the canonical web MVP
# ===========================
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ===========================
# Optional legacy/experimental backend Supabase values; service-role injection is rejected in controlled-demo
# ===========================
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ===========================
# Server Configuration
# ===========================
LIFEOS_OPERATING_MODE=local-dev
PORT=3001
# Leave VITE_API_BASE_URL unset for the canonical Vite proxy. Set only for an alternate API origin.
# VITE_API_BASE_URL=
LIFEOS_MVP_REPOSITORY=file
# Set only with LIFEOS_MVP_REPOSITORY=prisma.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lifeos

# ===========================
# AI Provider Keys
# ===========================
# GEMINI_API_KEY=
# GROQ_API_KEY=

# ===========================
# Context Gateway API Keys
# ===========================
# METEOSOURCE_API_KEY=
# COINGECKO_API_KEY=
# CURRENCYFREAKS_API_KEY=
# NEWS_API_KEY=

# ===========================
# Unsplash API (for images)
# ===========================
# UNSPLASH_ACCESS_KEY=
# UNSPLASH_SECRET_KEY=

# ===========================
# Authentication
# ===========================
# JWT_SECRET is migration compatibility only; prefer a generated LIFEOS_SESSION_SECRET.
# JWT_SECRET=
# LIFEOS_SESSION_SECRET=$(openssl rand -hex 32)
# This fallback-shaped seed is local-dev only; controlled-demo requires unique non-fallback values.
LIFEOS_INVITES=[{"email":"partner@example.com","code":"LIFEOS-INVITE","fullName":"Design Partner"}]
# Optional comma-separated exact emails. Empty means no administrator is authorized.
LIFEOS_ADMIN_EMAILS=
VITE_ENABLE_INTERNAL_MVP_ADMIN=false
VITE_BYPASS_MVP_INVITE_GATE=false
