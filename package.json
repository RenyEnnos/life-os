{
  "name": "life-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.lifeos.app",
    "productName": "Life OS",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "scripts": {
    "client:dev": "vite --host 0.0.0.0",
    "electron:dev": "vite",
    "electron:full": "concurrently \"npm run server:dev\" \"npm run electron:dev\"",
    "electron:build": "tsc -b && vite build && electron-builder",
    "android:dev": "npm run build && npx cap sync && npx cap open android",
    "android:build": "npm run build && npx cap sync",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "server:dev": "nodemon --watch api --ext ts,js,json --exec tsx api/server.ts",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "prebuild": "npm run check && npm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run src/features/**/__tests__/*.int.test.tsx",
    "test:e2e": "playwright test",
    "test:seed-perf-data": "tsx scripts/seed_perf_test_data.ts",
    "test:perf": "npm run test:e2e -- tests/performance/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "types:generate": "supabase gen types typescript --project-id $PROJECT_ID > src/shared/types/database.ts",
    "lh": "node scripts/lighthouse.js",
    "analyze": "node scripts/analyze-bundle.js",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "generate:robots": "node scripts/generate-robots.js",
    "seo:generate": "npm run generate:sitemap && npm run generate:robots -- --production"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/local-notifications": "^8.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@remixicon/react": "^4.9.0",
    "@sentry/node": "^10.42.0",
    "@sentry/react": "^10.42.0",
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.24",
    "@tremor/react": "^3.18.7",
    "@types/bcryptjs": "^3.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.18.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "electron-window-state": "^5.0.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.0",
    "fractional-indexing": "^3.2.0",
    "framer-motion": "^12.35.0",
    "googleapis": "^136.0.0",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "idb-keyval": "^6.2.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.71.2",
